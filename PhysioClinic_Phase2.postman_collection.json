{
  "info": {
    "name": "PhysioTherapy Clinic — Phase 2",
    "_postman_id": "physio-phase2-collection",
    "description": "Full CRUD smoke-tests for Services, Patients, Referrals, Appointments, and Session Notes.\nRun the collection in order — each POST captures its returned id into a collection variable so subsequent requests can reference it automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",       "value": "http://127.0.0.1:8000", "type": "string" },
    { "key": "service_id",     "value": "", "type": "string" },
    { "key": "patient_id",     "value": "", "type": "string" },
    { "key": "referral_id",    "value": "", "type": "string" },
    { "key": "appointment_id", "value": "", "type": "string" },
    { "key": "session_id",     "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "0 — Health & Schema",
      "item": [
        {
          "name": "0.1 Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/", "host": ["{{base_url}}"], "path": [""] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('status is ok', () => pm.expect(pm.response.json().status).to.eql('ok'));"
                ]
              }
            }
          ]
        },
        {
          "name": "0.2 OpenAPI Schema",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/openapi.json", "host": ["{{base_url}}"], "path": ["openapi.json"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('has openapi field', () => pm.expect(pm.response.json()).to.have.property('openapi'));",
                  "pm.test('has paths field',   () => pm.expect(pm.response.json()).to.have.property('paths'));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "1 — Services",
      "item": [
        {
          "name": "1.1 List all services",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/services", "host": ["{{base_url}}"], "path": ["services"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('returns array of 10 services', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.be.an('array').with.lengthOf(10);",
                  "});",
                  "pm.test('first item has expected fields', () => {",
                  "    const svc = pm.response.json()[0];",
                  "    pm.expect(svc).to.have.all.keys('id','name','tagline','description','duration_minutes','is_active','created_at');",
                  "});",
                  "// Save first service id for later requests",
                  "const firstId = pm.response.json()[0].id;",
                  "pm.collectionVariables.set('service_id', firstId);"
                ]
              }
            }
          ]
        },
        {
          "name": "1.2 Get service by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/services/{{service_id}}", "host": ["{{base_url}}"], "path": ["services", "{{service_id}}"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('id matches', () => {",
                  "    pm.expect(pm.response.json().id).to.eql(pm.collectionVariables.get('service_id'));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "1.3 Get non-existent service → 404",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/services/00000000-0000-0000-0000-000000000000", "host": ["{{base_url}}"], "path": ["services", "00000000-0000-0000-0000-000000000000"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('404 Not Found', () => pm.response.to.have.status(404));"
                ]
              }
            }
          ]
        }
      ]
    },
