### Step 2.3: Event Consumer Service

**File: `backend\Services\EventConsumer\ReferralEventConsumer.cs`**

```csharp
namespace CLINICSYSTEM.Services.EventConsumer
{
    public interface IReferralEventConsumer
    {
        Task HandleReferralAcceptedAsync(ReferralAcceptedEvent @event);
        Task HandleAppointmentScheduledAsync(AppointmentScheduledEvent @event);
        Task HandleSessionCompletedAsync(SessionCompletedEvent @event);
        Task HandleImagingCompletedAsync(ImagingCompletedEvent @event);
    }

    public class ReferralEventConsumer : IReferralEventConsumer
    {
        private readonly ClinicDbContext _context;
        private readonly IExternalPatientIdService _patientIdService;
        private readonly ILogger<ReferralEventConsumer> _logger;

        public async Task HandleReferralAcceptedAsync(ReferralAcceptedEvent @event)
        {
            try
            {
                // Find referral by external patient ID
                var localPatientId = await _patientIdService.GetLocalPatientIdAsync(@event.PatientExternalId);
                if (!localPatientId.HasValue)
                {
                    _logger.LogWarning($"Patient not found for external ID {@event.PatientExternalId}");
                    return;
                }

                // Update referral status
                var referral = await _context.Referrals
                    .FirstOrDefaultAsync(r => r.PatientExternalId == @event.PatientExternalId.ToString());

                if (referral != null)
                {
                    referral.Status = "Accepted_Ext";
                    referral.ExternalReferralId = @event.ExternalReferralId;
                    referral.UpdatedAt = DateTime.UtcNow;
                    
                    await _context.SaveChangesAsync();
                    _logger.LogInformation($"Referral {referral.ReferralId} accepted by Physiotherapy");
                }
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error handling ReferralAcceptedEvent");
                throw;
            }
        }

        // ... other handlers ...
    }
}
