### Step 2.4: Resilience Policies (Polly)

**File: `backend\Services\Resilience\ResiliencePolicies.cs`**

```csharp
namespace CLINICSYSTEM.Services.Resilience
{
    public static class ResiliencePolicies
    {
        // Circuit Breaker: Stop requesting if too many failures
        public static IAsyncPolicy<HttpResponseMessage> GetCircuitBreakerPolicy(IConfiguration config)
        {
            var settings = config.GetSection("Resilience:CircuitBreaker");
            var failureThreshold = int.Parse(settings["FailureThreshold"] ?? "50");
            var timeoutSeconds = int.Parse(settings["TimeoutSeconds"] ?? "30");

            return Policy
                .Handle<HttpRequestException>()
                .OrResult<HttpResponseMessage>(r => !r.IsSuccessStatusCode)
                .CircuitBreakerAsync<HttpResponseMessage>(
                    handledEventsAllowedBeforeBreaking: failureThreshold,
                    durationOfBreak: TimeSpan.FromSeconds(timeoutSeconds),
                    onBreak: (outcome, timespan) =>
                    {
                        // Log circuit opened
                    },
                    onReset: () =>
                    {
                        // Log circuit closed
                    }
                );
        }

        // Retry: Try again with exponential backoff
        public static IAsyncPolicy<HttpResponseMessage> GetRetryPolicy(IConfiguration config)
        {
            var settings = config.GetSection("Resilience:Retry");
            var maxAttempts = int.Parse(settings["MaxAttempts"] ?? "4");
            var initialDelayMs = int.Parse(settings["InitialDelayMs"] ?? "100");
            var backoffMultiplier = double.Parse(settings["BackoffMultiplier"] ?? "2.0");

            return Policy
                .Handle<HttpRequestException>()
                .OrResult<HttpResponseMessage>(r => !r.IsSuccessStatusCode)
                .WaitAndRetryAsync<HttpResponseMessage>(
                    retryCount: maxAttempts,
                    sleepDurationProvider: retryAttempt =>
                        TimeSpan.FromMilliseconds(
                            initialDelayMs * Math.Pow(backoffMultiplier, retryAttempt - 1)
                        )
                );
        }

        // Combine both policies
        public static IAsyncPolicy<HttpResponseMessage> GetCombinedPolicy(IConfiguration config)
        {
            return Policy.WrapAsync(
                GetRetryPolicy(config),
                GetCircuitBreakerPolicy(config)
            );
        }
    }
}
```

