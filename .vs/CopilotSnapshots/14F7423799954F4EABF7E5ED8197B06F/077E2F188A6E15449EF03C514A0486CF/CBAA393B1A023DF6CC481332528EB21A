using Microsoft.AspNetCore.Authorization;
using Microsoft.AspNetCore.Mvc;
using CLINICSYSTEM.Events;
using CLINICSYSTEM.Services.EventConsumer;

namespace CLINICSYSTEM.Controllers
{
    /// <summary>
    /// Webhook endpoints for receiving integration callbacks from external systems
    /// Used when direct event messaging is not available
    /// </summary>
    [ApiController]
    [Route("api/[controller]")]
    [Authorize]
    public class ExternalIntegrationController : ControllerBase
    {
        private readonly ReferralAcceptedEventConsumer _referralAcceptedConsumer;
        private readonly AppointmentScheduledEventConsumer _appointmentScheduledConsumer;
        private readonly SessionCompletedEventConsumer _sessionCompletedConsumer;
        private readonly ImagingCompletedEventConsumer _imagingCompletedConsumer;
        private readonly ILogger<ExternalIntegrationController> _logger;

        public ExternalIntegrationController(
            ReferralAcceptedEventConsumer referralAcceptedConsumer,
            AppointmentScheduledEventConsumer appointmentScheduledConsumer,
            SessionCompletedEventConsumer sessionCompletedConsumer,
            ImagingCompletedEventConsumer imagingCompletedConsumer,
            ILogger<ExternalIntegrationController> logger)
        {
            _referralAcceptedConsumer = referralAcceptedConsumer;
            _appointmentScheduledConsumer = appointmentScheduledConsumer;
            _sessionCompletedConsumer = sessionCompletedConsumer;
            _imagingCompletedConsumer = imagingCompletedConsumer;
            _logger = logger;
        }

        /// <summary>
        /// Webhook endpoint: Physiotherapy accepts referral
        /// </summary>
        [HttpPost("referral/accepted")]
        [ProducesResponseType(StatusCodes.Status200OK)]
        [ProducesResponseType(StatusCodes.Status400BadRequest)]
        [ProducesResponseType(StatusCodes.Status500InternalServerError)]
        public async Task<IActionResult> ReferralAccepted([FromBody] ReferralAcceptedEvent @event)
        {
            try
            {
                if (@event == null)
                    return BadRequest(new { message = "Event cannot be null" });

                _logger.LogInformation($"Received ReferralAccepted webhook for patient {@event.PatientExternalId}");
                
                // Create mock consume context and process
                await _referralAcceptedConsumer.Consume(
                    new MockConsumeContext<ReferralAcceptedEvent>(@event)
                );

                return Ok(new { message = "Referral acceptance processed successfully" });
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error processing ReferralAccepted webhook");
                return StatusCode(500, new { message = "Error processing event", error = ex.Message });
            }
        }

        /// <summary>
        /// Webhook endpoint: Physiotherapy schedules appointment
        /// </summary>
        [HttpPost("appointment/scheduled")]
        [ProducesResponseType(StatusCodes.Status200OK)]
        [ProducesResponseType(StatusCodes.Status400BadRequest)]
        [ProducesResponseType(StatusCodes.Status500InternalServerError)]
