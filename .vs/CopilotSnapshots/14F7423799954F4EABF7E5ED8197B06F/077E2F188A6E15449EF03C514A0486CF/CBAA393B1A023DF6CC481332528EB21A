                await _appointmentScheduledConsumer.Consume(
                    new MockConsumeContext<AppointmentScheduledEvent>(@event)
                );

                return Ok(new { message = "Appointment scheduled processed successfully" });
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error processing AppointmentScheduled webhook");
                return StatusCode(500, new { message = "Error processing event", error = ex.Message });
            }
        }

        /// <summary>
        /// Webhook endpoint: Physiotherapy completes therapy session
        /// </summary>
        [HttpPost("session/completed")]
        [ProducesResponseType(StatusCodes.Status200OK)]
        [ProducesResponseType(StatusCodes.Status400BadRequest)]
        [ProducesResponseType(StatusCodes.Status500InternalServerError)]
        public async Task<IActionResult> SessionCompleted([FromBody] SessionCompletedEvent @event)
        {
            try
            {
                if (@event == null)
