            }
        }

        /// <summary>
        /// Health check endpoint: Verify system connectivity
        /// </summary>
        [HttpGet("health")]
        [AllowAnonymous]
        [ProducesResponseType(StatusCodes.Status200OK)]
        public IActionResult HealthCheck()
        {
            return Ok(new
            {
                status = "healthy",
                timestamp = DateTime.UtcNow,
                version = "1.0",
                integration = new
                {
                    rabbitmq = "configured",
                    redis = "configured",
                    externalSystems = new[] { "physiotherapy", "radiology" }
                }
            });
        }
    }

    /// <summary>
    /// Mock ConsumeContext for testing without MassTransit
    /// </summary>
    internal class MockConsumeContext<T> : ConsumeContext<T> where T : class
    {
        private readonly T _message;

        public MockConsumeContext(T message)
        {
            _message = message;
        }

        public T Message => _message;

        public virtual Task NotifyConsumed(TimeSpan duration, string consumerType)
        {
            return Task.CompletedTask;
        }

        public virtual Task NotifyFaulted(TimeSpan duration, string consumerType, Exception exception)
        {
            return Task.CompletedTask;
        }
    }
}
