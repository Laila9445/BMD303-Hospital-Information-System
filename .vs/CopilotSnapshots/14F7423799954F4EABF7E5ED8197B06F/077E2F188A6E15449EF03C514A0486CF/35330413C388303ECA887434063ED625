    /// <summary>
    /// MassTransit consumer for ImagingCompletedEvent from Radiology system
    /// </summary>
    public class ImagingCompletedEventConsumer : IConsumer<ImagingCompletedEvent>
    {
        private readonly ClinicDbContext _context;
        private readonly IExternalPatientIdService _patientIdService;
        private readonly ILogger<ImagingCompletedEventConsumer> _logger;

        public ImagingCompletedEventConsumer(
            ClinicDbContext context,
            IExternalPatientIdService patientIdService,
            ILogger<ImagingCompletedEventConsumer> logger)
        {
            _context = context;
            _patientIdService = patientIdService;
            _logger = logger;
        }

        public async Task Consume(ConsumeContext<ImagingCompletedEvent> context)
        {
            await HandleEvent(context.Message);
        }

        public async Task HandleEvent(ImagingCompletedEvent @event)
        {
            try
            {
                _logger.LogInformation($"Processing ImagingCompletedEvent for patient {@event.PatientExternalId}");

                var localPatientId = await _patientIdService.GetLocalPatientIdAsync(@event.PatientExternalId);
                if (!localPatientId.HasValue)
                {
                    _logger.LogWarning($"Patient not found for external ID {@event.PatientExternalId}");
                    return;
                }

                _logger.LogInformation($"Imaging {@event.ImagingId} completed. Storage URL: {@event.StorageUrl}");
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error processing ImagingCompletedEvent");
                throw;
            }
        }
    }
}
