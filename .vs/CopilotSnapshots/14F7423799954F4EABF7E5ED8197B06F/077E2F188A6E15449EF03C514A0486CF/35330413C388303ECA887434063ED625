using MassTransit;
using CLINICSYSTEM.Events;
using CLINICSYSTEM.Data;

namespace CLINICSYSTEM.Services.EventConsumer
{
    /// <summary>
    /// MassTransit consumer for ReferralAcceptedEvent from Physiotherapy system
    /// </summary>
    public class ReferralAcceptedEventConsumer : IConsumer<ReferralAcceptedEvent>
    {
        private readonly ClinicDbContext _context;
        private readonly IExternalPatientIdService _patientIdService;
        private readonly ILogger<ReferralAcceptedEventConsumer> _logger;

        public ReferralAcceptedEventConsumer(
            ClinicDbContext context,
            IExternalPatientIdService patientIdService,
            ILogger<ReferralAcceptedEventConsumer> logger)
        {
            _context = context;
            _patientIdService = patientIdService;
            _logger = logger;
        }

        public async Task Consume(ConsumeContext<ReferralAcceptedEvent> context)
        {
            await HandleEvent(context.Message);
        }

        public async Task HandleEvent(ReferralAcceptedEvent @event)
        {
            try
            {
                _logger.LogInformation($"Processing ReferralAcceptedEvent for patient {@event.PatientExternalId}");

                var referral = await _context.Referrals
                    .FirstOrDefaultAsync(r => r.PatientExternalId == @event.PatientExternalId.ToString());

                if (referral == null)
                {
                    _logger.LogWarning($"Referral not found for patient {@event.PatientExternalId}");
                    return;
                }

                referral.Status = "Accepted_Ext";
                referral.ExternalReferralId = @event.ExternalReferralId?.ToString();
                referral.ExternalSyncedAt = DateTime.UtcNow;
                referral.ExternalSyncAttempts = (referral.ExternalSyncAttempts ?? 0) + 1;
                referral.AcceptedAt = DateTime.UtcNow;

                await _context.SaveChangesAsync();
                _logger.LogInformation($"Referral {referral.ReferralId} accepted by Physiotherapy");
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error processing ReferralAcceptedEvent");
                throw;
            }
        }
    }

