using Microsoft.AspNetCore.Authorization;
using Microsoft.AspNetCore.Mvc;
using CLINICSYSTEM.Data.DTOs;
using CLINICSYSTEM.Services;

namespace CLINICSYSTEM.Controllers
{
 
    [ApiController]
    [Route("api/[controller]")]
    [Authorize]
    public class ImagingController : ControllerBase
    {
        private readonly IImagingService _imagingService;
        private readonly ILogger<ImagingController> _logger;

        public ImagingController(
            IImagingService imagingService,
            ILogger<ImagingController> logger)
        {
            _imagingService = imagingService;
            _logger = logger;
        }

       
        [HttpPost]
        [ProducesResponseType(typeof(MedicalImagingDTO), StatusCodes.Status201Created)]
        [ProducesResponseType(StatusCodes.Status400BadRequest)]
        public async Task<IActionResult> CreateImagingRequest([FromBody] CreateMedicalImagingRequest request)
        {
            try
            {
                var imaging = await _imagingService.CreateImagingRequestAsync(request);
                return CreatedAtAction(nameof(GetImaging), new { id = imaging.ImagingId }, imaging);
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error creating imaging request");
                return StatusCode(500, new { message = "Error creating imaging request" });
            }
        }

        /// <summary>
        /// Get imaging by ID
        /// </summary>
        [HttpGet("{id}")]
        [ProducesResponseType(typeof(MedicalImagingDTO), StatusCodes.Status200OK)]
        [ProducesResponseType(StatusCodes.Status404NotFound)]
        public async Task<IActionResult> GetImaging(int id)
        {
            try
            {
                var imaging = await _imagingService.GetImagingByIdAsync(id);
                return Ok(imaging);
            }
            catch (KeyNotFoundException ex)
            {
                return NotFound(new { message = ex.Message });
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, $"Error retrieving imaging {id}");
                return StatusCode(500, new { message = "Error retrieving imaging" });
            }
        }

        /// <summary>
        /// Get all imaging for a patient
        /// </summary>
        [HttpGet("patient/{patientExternalId}")]
        [ProducesResponseType(typeof(List<MedicalImagingDTO>), StatusCodes.Status200OK)]
        public async Task<IActionResult> GetPatientImaging(Guid patientExternalId)
        {
            try
            {
                var imagings = await _imagingService.GetPatientImagingAsync(patientExternalId);
                return Ok(imagings);
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error retrieving patient imaging");
                return StatusCode(500, new { message = "Error retrieving imaging" });
            }
        }

        /// <summary>
        /// Get imaging for a referral
        /// </summary>
        [HttpGet("referral/{referralId}")]
        [ProducesResponseType(typeof(List<MedicalImagingDTO>), StatusCodes.Status200OK)]
        public async Task<IActionResult> GetReferralImaging(int referralId)
        {
            try
            {
                var imagings = await _imagingService.GetReferralImagingAsync(referralId);
                return Ok(imagings);
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error retrieving referral imaging");
                return StatusCode(500, new { message = "Error retrieving imaging" });
            }
        }

        /// <summary>
        /// Update imaging results (called by Radiology system)
        /// </summary>
        [HttpPost("{id}/results")]
        [ProducesResponseType(typeof(MedicalImagingDTO), StatusCodes.Status200OK)]
        [ProducesResponseType(StatusCodes.Status404NotFound)]
        [AllowAnonymous]  // Radiology system calls this
        public async Task<IActionResult> UpdateImagingResults(int id, [FromBody] UpdateMedicalImagingRequest request)
        {
            try
            {
                var imaging = await _imagingService.UpdateImagingResultsAsync(id, request);
                return Ok(imaging);
            }
            catch (KeyNotFoundException ex)
            {
                return NotFound(new { message = ex.Message });
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, $"Error updating imaging {id}");
                return StatusCode(500, new { message = "Error updating imaging" });
            }
        }
    }
}
