using Microsoft.AspNetCore.Authorization;
using Microsoft.AspNetCore.Mvc;
using CLINICSYSTEM.Data.DTOs;
using CLINICSYSTEM.Services;

namespace CLINICSYSTEM.Controllers
{
    /// <summary>
    /// Patient timeline aggregation endpoints
    /// Provides unified view of all patient activities across all systems
    /// </summary>
    [ApiController]
    [Route("api/[controller]")]
    [Authorize]
    public class PatientTimelineController : ControllerBase
    {
        private readonly IPatientTimelineService _timelineService;
        private readonly ILogger<PatientTimelineController> _logger;

        public PatientTimelineController(
            IPatientTimelineService timelineService,
            ILogger<PatientTimelineController> logger)
        {
            _timelineService = timelineService;
            _logger = logger;
        }

        /// <summary>
        /// Get complete patient timeline (all activities aggregated)
        /// Combines: Visits, Referrals, Imaging, Therapy Sessions, Prescriptions
        /// </summary>
        [HttpPost("patient/{patientExternalId}")]
        [ProducesResponseType(typeof(PatientTimelineDTO), StatusCodes.Status200OK)]
        [ProducesResponseType(StatusCodes.Status404NotFound)]
        public async Task<IActionResult> GetPatientTimeline(
            Guid patientExternalId,
            [FromBody] GetPatientTimelineRequest? request = null)
        {
            try
            {
                request ??= new GetPatientTimelineRequest { PatientExternalId = patientExternalId };
                var timeline = await _timelineService.GetPatientTimelineAsync(patientExternalId, request);
                return Ok(timeline);
            }
            catch (KeyNotFoundException ex)
            {
                return NotFound(new { message = ex.Message });
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, $"Error retrieving patient timeline for {patientExternalId}");
                return StatusCode(500, new { message = "Error retrieving patient timeline" });
            }
        }

        /// <summary>
        /// Get patient timeline (simple GET version)
        /// </summary>
        [HttpGet("{patientExternalId}")]
        [ProducesResponseType(typeof(PatientTimelineDTO), StatusCodes.Status200OK)]
        [ProducesResponseType(StatusCodes.Status404NotFound)]
        public async Task<IActionResult> GetPatientTimelineSimple(Guid patientExternalId)
        {
            try
            {
                var timeline = await _timelineService.GetPatientTimelineAsync(patientExternalId);
                return Ok(timeline);
            }
            catch (KeyNotFoundException ex)
            {
                return NotFound(new { message = ex.Message });
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, $"Error retrieving patient timeline for {patientExternalId}");
                return StatusCode(500, new { message = "Error retrieving patient timeline" });
            }
        }

        /// <summary>
        /// Get detailed timeline events for a patient
        /// Chronological list of all activities
        /// </summary>
        [HttpGet("{patientExternalId}/events")]
        [ProducesResponseType(typeof(List<TimelineEventDTO>), StatusCodes.Status200OK)]
        public async Task<IActionResult> GetPatientEvents(
            Guid patientExternalId,
            [FromQuery] DateTime? fromDate = null,
            [FromQuery] DateTime? toDate = null)
        {
            try
            {
                var events = await _timelineService.GetPatientEventsAsync(patientExternalId, fromDate, toDate);
                return Ok(new
                {
                    count = events.Count,
                    events = events
                });
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, $"Error retrieving patient events for {patientExternalId}");
                return StatusCode(500, new { message = "Error retrieving events" });
            }
        }

        /// <summary>
        /// Get pain score trend for a patient
        /// Shows pain improvement over therapy sessions
        /// </summary>
        [HttpGet("{patientExternalId}/pain-trend")]
        [ProducesResponseType(typeof(List<PainScoreTrendDTO>), StatusCodes.Status200OK)]
        public async Task<IActionResult> GetPainScoreTrend(Guid patientExternalId)
        {
            try
            {
                var trend = await _timelineService.GetPainScoreTrendAsync(patientExternalId);
                
                var response = new
                {
                    patientExternalId = patientExternalId,
                    totalSessions = trend.Count,
                    averageImprovement = trend.Any() ? trend.Average(t => t.Improvement) : 0,
                    trend = trend
                };

                return Ok(response);
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, $"Error retrieving pain trend for {patientExternalId}");
                return StatusCode(500, new { message = "Error retrieving pain trend" });
            }
        }

        /// <summary>
        /// Get patient summary (quick stats)
        /// </summary>
        [HttpGet("{patientExternalId}/summary")]
        [ProducesResponseType(StatusCodes.Status200OK)]
        public async Task<IActionResult> GetPatientSummary(Guid patientExternalId)
        {
            try
            {
                var timeline = await _timelineService.GetPatientTimelineAsync(patientExternalId);
                
                var summary = new
                {
                    patientName = timeline.PatientName,
                    patientExternalId = timeline.PatientExternalId,
                    statistics = new
                    {
                        totalVisits = timeline.TotalVisits,
                        totalReferrals = timeline.TotalReferrals,
                        activeReferrals = timeline.ActiveReferrals,
                        totalImagingTests = timeline.TotalImagingTests,
                        totalTherapySessions = timeline.TotalTherapySessions
                    },
                    progress = new
                    {
                        latestPainBefore = timeline.LatestPainScoreBefore,
                        latestPainAfter = timeline.LatestPainScoreAfter,
                        averagePainImprovement = timeline.AveragePainImprovement
                    },
                    upcoming = new
                    {
                        nextAppointmentDate = timeline.NextAppointmentDate,
                        nextAppointmentType = timeline.NextAppointmentType
                    }
                };

                return Ok(summary);
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, $"Error retrieving patient summary for {patientExternalId}");
                return StatusCode(500, new { message = "Error retrieving summary" });
            }
        }
    }
}
