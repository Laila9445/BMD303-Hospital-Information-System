    {
      "name": "5 \u2013 Session Notes",
      "item": [
        {
          "name": "5.1 Create session note (appt \u2192 completed, referral \u2192 completed)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('201 Created', () => pm.response.to.have.status(201));",
            "const body = pm.response.json();",
            "pm.test('shape correct', () => pm.expect(body).to.have.all.keys('id','appointment_id','patient_id','therapist_name','assessment','treatment','home_exercises','pain_score_before','pain_score_after','next_appointment_date','created_at'));",
            "pm.test('appointment_id matches', () => pm.expect(body.appointment_id).to.eql(pm.collectionVariables.get('appointment_id')));",
            "pm.test('patient_id matches',     () => pm.expect(body.patient_id).to.eql(pm.collectionVariables.get('patient_id')));",
            "pm.test('pain_score_before = 7',  () => pm.expect(body.pain_score_before).to.eql(7));",
            "pm.test('pain_score_after = 4',   () => pm.expect(body.pain_score_after).to.eql(4));",
            "pm.test('next_appointment_date',  () => pm.expect(body.next_appointment_date).to.eql('2026-04-08'));",
            "pm.collectionVariables.set('session_id', body.id);",
