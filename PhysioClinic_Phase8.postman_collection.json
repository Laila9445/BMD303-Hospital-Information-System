        {
            "name": "Setup: Setup Service & Referral",
            "event": [
                {
                    "listen": "prerequest",
                    "script": {
                        "exec": [
                            "pm.sendRequest(pm.variables.get(\"base_url\") + \"/api/services\", function (err, res) {",
                            "    if (err) {",
                            "        console.log(err);",
                            "    } else {",
                            "        var services = res.json();",
                            "        if (services.length > 0) {",
                            "            pm.collectionVariables.set(\"service_id\", services[0].id);",
                            "        }",
                            "    }",
                            "});"
                        ],
                        "type": "text/javascript"
                    }
                },
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "pm.test(\"Status code is 200 or 201\", function () {",
                            "    pm.expect(pm.response.code).to.be.oneOf([200,201]);",
                            "});",
                            "var responseData = pm.response.json();",
                            "pm.collectionVariables.set(\"referral_id\", responseData.referral.id);"
                        ],
                        "type": "text/javascript"
                    }
                }
            ],
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Authorization",
                        "value": "Bearer {{access_token}}"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\"patient_name\": \"Khaled Mostafa\", \"patient_phone\": \"+201011112222\", \"service_id\": \"{{service_id}}\", \"referring_doctor\": \"Dr. Magdi\"}",
                    "options": {
                        "raw": {
                            "language": "json"
                        }
                    }
                },
                "url": {
                    "raw": "{{base_url}}/api/referrals",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "api",
                        "referrals"
                    ]
                }
            },
            "response": []
        },
